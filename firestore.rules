rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ───────────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Validates a campaign write — allows all fields from Campaign interface
    // (src/lib/db/types.ts + extended fields written by BuyAds.tsx)
    function isValidCampaign(data) {
      let allowed = [
        'name', 'budgetSats', 'status', 'createdAt', 'updatedAt',
        // Analytics / display
        'dates', 'platforms', 'spendBtc', 'spendUsd', 'impressions', 'clicks',
        'ctr', 'cpc', 'pacing', 'payment',
        // Creative
        'headline', 'description', 'url', 'targetUrl',
        'bgHue', 'bgLightness', 'textColor',
        // Ownership / payment tracking
        'userId', 'invoiceId', 'paymentConfirmedAt',
        // Targeting (written by StepTargeting)
        'targeting', 'targeting.interests', 'targeting.ageMin', 'targeting.ageMax',
        'targeting.countries', 'targeting.languages', 'targeting.devices',
        'targeting.networks', 'targeting.sex', 'targeting.education',
        'targeting.income', 'targeting.behaviors', 'targeting.industries',
        'targeting.pixelUrl',
        // Scheduling
        'scheduling', 'scheduleStart', 'scheduleEnd', 'blockHeight',
        // PPQ / A/B
        'ppq', 'ppqEnabled', 'ppqGoal', 'abVariants', 'weights', 'advancedMode',
        // Extra fields that may be added
        'imageUrl', 'hashtags',
      ];
      return data.keys().hasOnly(allowed) &&
             data.name is string &&
             data.name.size() > 0 &&
             data.name.size() <= 100 &&
             data.budgetSats is number &&
             data.budgetSats >= 0 &&
             data.status in ['draft', 'live', 'paused', 'completed'] &&
             data.createdAt is string &&
             // Ownership required — no orphan/shared campaigns
             data.keys().hasAll(['userId']) &&
             data.userId is string &&
             data.userId == request.auth.uid;
    }

    function isCampaignOwner() {
      return isAuthenticated() &&
             resource.data.keys().hasAll(['userId']) &&
             resource.data.userId is string &&
             resource.data.userId == request.auth.uid;
    }

    // ─── Campaigns Collection ───────────────────────────────────────────────
    match /campaigns/{campaignId} {
      // Only the owner may read their campaigns
      allow read: if isCampaignOwner();

      // Create only as owner with validated payload (prefer draft via app logic)
      allow create: if isAuthenticated() && isValidCampaign(request.resource.data);

      // Update/delete only by owner; cannot reassign userId
      allow update: if isCampaignOwner() &&
        request.resource.data.userId == resource.data.userId &&
        // Clients cannot self-promote to live without server path (still allow paused/draft)
        (
          request.resource.data.status == resource.data.status ||
          request.resource.data.status in ['draft', 'paused', 'completed'] ||
          // live only if already live (server uses Admin SDK which bypasses rules)
          (resource.data.status == 'live' && request.resource.data.status == 'live')
        );

      allow delete: if isCampaignOwner();
    }

    // ─── Bids Collection ────────────────────────────────────────────────────
    match /bids/{bidId} {
      allow read: if isAuthenticated() &&
        resource.data.keys().hasAll(['userId']) &&
        resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() &&
        request.resource.data.keys().hasAll(['slotId', 'bidSats', 'userId']) &&
        request.resource.data.bidSats is number &&
        request.resource.data.bidSats > 0 &&
        request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() &&
        resource.data.keys().hasAll(['userId']) &&
        resource.data.userId == request.auth.uid;
    }

    // ─── Publisher Settings ─────────────────────────────────────────────────
    match /publisher_settings/{userId} {
      allow read, write: if isOwner(userId);
    }

    // ─── User Profiles ───────────────────────────────────────────────────────
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

  }
}
