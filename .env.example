# Required Environment Variables

# --- Client-side Firebase (Vite) ---
# These are exposed to the browser via import.meta.env
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Optional: set to a named Firestore database id (defaults to "(default)")
VITE_FIRESTORE_DATABASE_ID=

# --- Server-side Firebase Admin ---
# JSON string of the Firebase service account key
FIREBASE_SERVICE_ACCOUNT_KEY=
# Fallback project ID used for warnings (server-side only)
FIREBASE_PROJECT_ID=

# --- Server ---
# Secret used to sign session cookies — set a long random string in production
SESSION_SECRET=

# --- AI ---
GEMINI_API_KEY=

# --- Observability ---
SENTRY_DSN=

# --- Agent Auth ---
# Comma-separated list of valid agent API keys
AGENT_API_KEYS=
