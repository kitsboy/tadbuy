# ═══════════════════════════════════════════════════════════════════════
# TadBuy Metrics — Environment Configuration
# Copy to .env and customize.
#
# cp .env.example .env
# ═══════════════════════════════════════════════════════════════════════

# ── Server ──────────────────────────────────────────────────────────────
PORT=8080
# HOST=0.0.0.0

# ── Data Directory ──────────────────────────────────────────────────────
# Where JSON data files are stored (inside the container this is /data/tadbuy-metrics)
# DATA_DIR=/data/tadbuy-metrics

# ── BTC + Multi-Currency Price Source ───────────────────────────────────
# Default: CoinGecko free API — returns USD, CAD, EUR, GBP simultaneously
# No API key needed. Refreshed every 5 minutes.
BTC_PRICE_URL=https://api.coingecko.com/api/v3/simple/price?ids=bitcoin&vs_currencies=usd,cad,eur,gbp

# ── Brave Search (optional) ─────────────────────────────────────────────
# Enables live scraping of X/Twitter ad benchmarks from the web.
# Without this key, the scraper uses quarterly hardcoded fallback benchmarks.
# Free tier available at: https://brave.com/search/api/
BRAVE_API_KEY=

# ── Cost-of-Value Parameters ─────────────────────────────────────────────
# Baseline estimates for energy-backed BTC valuation.
# Adjust based on current mining economics.

# Average electricity cost to mine 1 BTC (USD)
COV_ENERGY_COST_USD=14500

# Hardware amortization + facility costs per BTC (USD)
COV_MINING_COST_USD=9500

# Capital opportunity cost per BTC (USD)
COV_OPPORTUNITY_COST_USD=3000

# Signal thresholds
# Buy signal:  market price < true cost by this % (e.g. -0.20 = 20% below)
COV_BUY_THRESHOLD=-0.20

# Sell signal: market price > true cost by this % (e.g. 0.30 = 30% above)
COV_SELL_THRESHOLD=0.30

# ── Scraper Settings ─────────────────────────────────────────────────────
SCRAPER_MAX_RETRIES=3
SCRAPER_RETRY_DELAY=10
