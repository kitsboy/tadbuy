# ═══════════════════════════════════════════════════════════════════
# Tadbuy — Required Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ═══════════════════════════════════════════════════════════════════

# ─── Client-side Firebase (Vite — exposed to browser) ──────────────
# These are safe to expose — Firebase client keys are not secrets.
# Get them from: Firebase Console → Project Settings → Your Apps
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Optional: named Firestore database (defaults to "(default)")
VITE_FIRESTORE_DATABASE_ID=

# ─── Server-side Supabase (NEVER expose service role to browser) ───
# Get from: https://supabase.com/dashboard/project/cegzfjbsadwchonpxwmv/settings/api
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Server-side Firebase Admin (legacy — client auth still uses VITE_FIREBASE_*) ─
# Only needed if reverting to Firestore admin. Server now uses Supabase.
# FIREBASE_SERVICE_ACCOUNT_KEY=
# FIREBASE_PROJECT_ID=

# ─── Server ────────────────────────────────────────────────────────
# Long random string for signing session cookies.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# REQUIRED in production — server will refuse to start without it.
SESSION_SECRET=

# ─── Lightning Network (LND via Umbrel) ────────────────────────────
# Required for real Lightning invoice creation, payment polling, and withdrawals.
# TLS cert: base64-encoded contents of ~/.lnd/tls.cert on your Umbrel node
# Macaroon: base64-encoded contents of ~/.lnd/data/chain/bitcoin/mainnet/admin.macaroon
# Socket: host:port of your LND gRPC interface (e.g. umbrel.local:10009)
UMBREL_LND_CERT=
UMBREL_LND_MACAROON=
UMBREL_LND_SOCKET=

# ─── Observability ─────────────────────────────────────────────────
# Get from: https://sentry.io — create a Node.js project
SENTRY_DSN=

# ─── API Proxy (M4) ────────────────────────────────────────────────
# Cloudflare Pages is static-only. Set this when M4 API proxy is live.
# VITE_API_BASE_URL=https://api.giveabit.io

# ─── Fedimint Ecash ────────────────────────────────────────────────
# Federation invite code for ecash payments (fm-invite://...)
VITE_FEDIMINT_INVITE=
# Optional: federation gateway URL for server-side mint operations
FEDIMINT_GATEWAY_URL=
FEDIMINT_FEDERATION_NAME=Give A Bit Mint

# ─── Nostr ─────────────────────────────────────────────────────────
NOSTR_PUBKEY=

# ─── Agent API Keys ────────────────────────────────────────────────
# JSON object mapping API key strings to roles ("agent" or "admin").
# Used for the /api/agent/* routes (Nostr agents, automation, etc.)
# Example: AGENT_API_KEYS={"my-secret-key-123": "agent", "admin-key-456": "admin"}
AGENT_API_KEYS={}
