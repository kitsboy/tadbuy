# ═══════════════════════════════════════════════════════════════════
# Tadbuy — Required Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ═══════════════════════════════════════════════════════════════════

# ─── Client-side Firebase (Vite — exposed to browser) ──────────────
# These are safe to expose — Firebase client keys are not secrets.
# Get them from: Firebase Console → Project Settings → Your Apps
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Optional: named Firestore database (defaults to "(default)")
VITE_FIRESTORE_DATABASE_ID=

# ─── Server-side Firebase Admin (NEVER expose to browser) ──────────
# JSON string of the Firebase service account key.
# Get it from: Firebase Console → Project Settings → Service Accounts → Generate new private key
# Paste the entire JSON object as a single-line string.
FIREBASE_SERVICE_ACCOUNT_KEY=
# Fallback project ID for server-side warnings
FIREBASE_PROJECT_ID=

# ─── Server ────────────────────────────────────────────────────────
# Long random string for signing session cookies.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# REQUIRED in production — server will refuse to start without it.
SESSION_SECRET=

# ─── AI (Gemini) ───────────────────────────────────────────────────
# Used SERVER-SIDE ONLY by /api/ai/optimize proxy.
# Get from: https://aistudio.google.com/app/apikey
# Do NOT put this in VITE_* vars — it would be exposed in the browser bundle.
GEMINI_API_KEY=

# ─── Lightning Network (LND via Umbrel) ────────────────────────────
# Required for real Lightning invoice creation, payment polling, and withdrawals.
# TLS cert: base64-encoded contents of ~/.lnd/tls.cert on your Umbrel node
# Macaroon: base64-encoded contents of ~/.lnd/data/chain/bitcoin/mainnet/admin.macaroon
# Socket: host:port of your LND gRPC interface (e.g. umbrel.local:10009)
UMBREL_LND_CERT=
UMBREL_LND_MACAROON=
UMBREL_LND_SOCKET=

# ─── Observability ─────────────────────────────────────────────────
# Get from: https://sentry.io — create a Node.js project
SENTRY_DSN=

# ─── Agent API Keys ────────────────────────────────────────────────
# JSON object mapping API key strings to roles ("agent" or "admin").
# Used for the /api/agent/* routes (Nostr agents, automation, etc.)
# Example: AGENT_API_KEYS={"my-secret-key-123": "agent", "admin-key-456": "admin"}
AGENT_API_KEYS={}
